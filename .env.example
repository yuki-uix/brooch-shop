# ── Database (PostgreSQL / Supabase required) ──────────────
# Get these from: Supabase → Project Settings → Database → Connection String
# Use "Transaction" mode (port 6543) for DATABASE_URL (pooled)
# Use "Session" mode (port 5432) for DIRECT_URL (direct)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:5432/postgres"

# ── AI Provider ───────────────────────────────────────
# mock | openai | google | anthropic
AI_PROVIDER=mock
# 留空则使用各 provider 默认值（如 gpt-4o-mini / gemini-2.5-flash / claude-sonnet-4-20250514）
AI_MODEL=
# 仅在 AI_PROVIDER=mock 时生效，强制可行性：feasible | needs_confirmation | not_recommended
# AI_MOCK_SCENARIO=feasible

# OPENAI_API_KEY=sk-...
# GOOGLE_GENERATIVE_AI_API_KEY=...
# ANTHROPIC_API_KEY=sk-ant-...
